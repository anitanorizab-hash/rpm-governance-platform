# .env.example — copy to .env and fill values. NEVER commit .env. Secrets ONLY here (not in config.md).

# --- App ---
APP_PROFILE=development            # development | testing | production

# --- LLM / Embedding provider keys (set the ones your active profile uses) ---
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database (production overrides config.md placeholder) ---
DATABASE_URL=                      # e.g. postgresql+psycopg://user:pass@host:5432/govdb (prod)

# --- Auth (set in CP4) ---
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- Email/SMTP (set in CP for notifications) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
